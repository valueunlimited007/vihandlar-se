# vihandlar.se Environment Variables
# Copy this file to .env.local and fill in values

# =============================================================================
# Scanner - Google Cloud Vision OCR
# =============================================================================
GOOGLE_CLOUD_API_KEY=

# =============================================================================
# Voice Input - OpenAI Whisper
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Vercel KV - Delade listor (optional)
# https://vercel.com/docs/storage/vercel-kv
# =============================================================================
KV_REST_API_URL=
KV_REST_API_TOKEN=

# =============================================================================
# Supabase - ENDAST för data-export (kan tas bort efter migration)
# =============================================================================
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=

# =============================================================================
# Analytics (optional)
# =============================================================================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vihandlar.se
