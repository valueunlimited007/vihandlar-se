# vihandlar.se Environment Variables
# Copy this file to .env.local and fill in values

# =============================================================================
# Vercel KV (Redis) - Delade inköpslistor
# Sätts automatiskt när du kopplar Vercel KV i Vercel Dashboard.
# Utan dessa variabler används in-memory lagring (försvinner vid omstart).
# =============================================================================
KV_REST_API_URL=
KV_REST_API_TOKEN=

# =============================================================================
# Google Cloud Vision API - E-ämnesscanner (OCR)
# Behövs för att scanna bilder av ingredienslistor.
# Utan denna nyckel körs scanner i demo-läge med exempeldata.
# Skapa nyckel: https://console.cloud.google.com/apis/credentials
# Aktivera: Cloud Vision API
# =============================================================================
GOOGLE_CLOUD_API_KEY=

# =============================================================================
# OpenAI API - Röstinmatning (Whisper)
# Behövs för att konvertera röstinspelningar till text.
# Utan denna nyckel körs röstinmatning i demo-läge med exempelsvar.
# Skapa nyckel: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Supabase - ENDAST för data-export script (ej runtime)
# Behövs bara om du kör: npm run export-data
# =============================================================================
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=
